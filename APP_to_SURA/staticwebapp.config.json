{
  "routes": [
    {
      "route": "/operaciones*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/admin*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    }
  }
}